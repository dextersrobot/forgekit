# ─────────────────────────────────────────────────────────────
# ForgeKit (MIT core) environment variables
# Copy to .env.local and fill in. Never commit real values.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags — leave empty for the MIT core build
NEXT_PUBLIC_FEATURES=

# ── Clerk (https://dashboard.clerk.com) ──────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → Webhooks → endpoint: {APP_URL}/api/webhooks/clerk
# Subscribe to user.* events
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Postgres ─────────────────────────────────────────────────
# e.g. Neon, Supabase, or local: postgres://user:pass@localhost:5432/forgekit
DATABASE_URL=postgres://...

# ── Stripe (https://dashboard.stripe.com) ────────────────────
STRIPE_SECRET_KEY=sk_test_...
# Stripe Dashboard → Developers → Webhooks → endpoint: {APP_URL}/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the flat-rate monthly plan (recurring, licensed)
STRIPE_PRICE_ID_PRO=price_...

# ── AI providers (at least one required) ─────────────────────
# AI_PROVIDER: "openai" | "anthropic"
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (https://resend.com) ──────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="ForgeKit <notifications@yourdomain.com>"

# Usage threshold (units per month) that triggers a warning email
USAGE_ALERT_THRESHOLD=100000
